PORT=5000

# CouchDB — uses 5985 to avoid conflict with Fabric's CouchDB on 5984
COUCHDB_URL=http://admin:password@localhost:5985
COUCHDB_NAME=consent_db

# OPA
OPA_URL=http://localhost:8181

# OCR Service
OCR_SERVICE_URL=http://localhost:8000

# Hyperledger Fabric
# Set FABRIC_ENABLED=true after running: ./fabric/setup-fabric.sh
FABRIC_ENABLED=true
FABRIC_CHANNEL=platform
FABRIC_CHAINCODE=consent
FABRIC_ORG=Org1MSP
FABRIC_PEER=localhost:7051
FABRIC_ORDERER=localhost:7050
FABRIC_WALLET_PATH=./fabric-wallet
FABRIC_CONNECTION_PROFILE=./fabric-connection.json
